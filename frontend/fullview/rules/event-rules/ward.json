          "onResourceBlocked": "stay_source",
          "onEscortUnavailable": "continue_without_escort"
        },
        "patient_form_during_move": "stretcher",
        "final_form": "bed",
        "escort_required": true,
        "escort_roles": [
          "porter",
          "ward_nurse"
