      "movement": {
        "schema": "patient-move",
        "from": "ward_admission",
        "to": "target_ward_room",
        "via": [],
        "transport": "stretcher",
        "acuity": "routine",
        "patientFormDuringMove": "stretcher",
        "finalForm": "bed",
        "escortRequired": true,
        "escortRoles": [
          "porter",
          "ward_nurse"
        ],
        "equipment": [
          "transport_bag"
        ],
        "pathPolicy": {
          "requiresPath": true,
          "useElevator": false,
          "avoidWalls": true,
          "hallwayPreference": "center",
          "stopAtDoorBeforeEntering": true
        },
        "resourcePolicy": {
          "lockBeforeMove": true,
          "releaseSourceOnArrival": true,
          "occupyTargetOnArrival": true,
          "keepSourceReservedUntilArrival": false
        },
        "failurePolicy": {
