          "icu_beds_b",
          "icu_isolation",
          "intervention_bay"
        ],
        "via": [],
        "transport": "stretcher",
        "acuity": "critical",
        "patientFormDuringMove": "stretcher",
        "finalForm": "bed",
        "escortRequired": true,
        "escortRoles": [
          "porter",
          "icu_nurse"
        ],
        "equipment": [
          "portable_monitor",
          "oxygen",
          "transport_bag"
        ],
        "pathPolicy": {
          "requiresPath": true,
          "useElevator": false,
          "avoidWalls": true,
          "hallwayPreference": "center",
          "stopAtDoorBeforeEntering": true
        },
        "resourcePolicy": {
          "lockBeforeMove": true,
          "releaseSourceOnArrival": true,
          "occupyTargetOnArrival": true,
          "keepSourceReservedUntilArrival": true
        },
        "failurePolicy": {
