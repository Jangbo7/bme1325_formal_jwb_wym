        "icu_admission",
        "icu_beds_a",
        "icu_beds_b",
        "icu_isolation",
        "intervention_bay"
      ],
      "roomsText": "icu_admission、icu_beds_a、icu_beds_b、icu_isolation、intervention_bay",
      "agents": "患者、医生/护士、BedManager 或叫号/转运系统。",
      "prechecks": "目标 ICU 床位已锁定；患者资料完整。",
      "actions": "移动患者从 icu_admission 到目标 ICU 床位。",
      "successState": "患者状态为 ADMITTED；目标床位占用。",
