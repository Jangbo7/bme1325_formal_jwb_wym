    {
      "id": "movement-block-1",
      "name": "ICU 满床阻塞转运",
      "eventId": "BLOCK_MOVE_ICU_FULL",
      "classification": "移动阻塞",
      "trigger": "任意患者准备转入 ICU，但 ICU 无匹配空床。",
      "rooms": [
        "icu_beds_a",
        "icu_beds_b",
        "icu_isolation",
        "intervention_bay"
      ],
      "roomsText": "icu_beds_a、icu_beds_b、icu_isolation、intervention_bay",
      "agents": "患者、发起科室、接收科室、BedManager、转运系统。",
      "prechecks": "在移动前检查目标房间、床位、队列、路径和人员资源。",
      "actions": "患者留在原房间；目标 ICU 不占用；不启动路径。",
      "successState": "患者位置、原资源和目标资源保持一致，不发生错误释放。",
      "blocking": "患者留在原房间；目标 ICU 不占用；不启动路径。",
      "visualization": "患者不移动；相关房间或部门 snapshot 显示 warning/critical。",
      "movement": {
        "schema": "patient-move",
        "blocked": true,
        "blockedStage": "precheck",
        "patientPositionPolicy": "stay_source",
        "reason": "患者留在原房间；目标 ICU 不占用；不启动路径。",
        "resourcePolicy": {
          "lockBeforeMove": false,
          "doNotReleaseSource": true,
          "doNotOccupyTarget": true
        },
        "failurePolicy": {
          "onNoPath": "stay_source",
          "onResourceBlocked": "stay_source",
          "onEscortUnavailable": "stay_source"
        },
        "visualAlert": "warning"
      },
      "sourceFile": "patient-movement-curated",
      "event_id": "BLOCK_MOVE_ICU_FULL"
    },
