    {
      "id": "transfer-move-1",
      "name": "急诊转 ICU 标准路径",
      "eventId": "TRANSFER_ED_TO_ICU",
      "classification": "跨楼层移动",
      "trigger": "急诊患者需要 ICU 监护或抢救。",
      "rooms": [
        "ed_handoff",
        "elevator_1",
        "elevator_3",
        "icu_admission"
      ],
      "roomsText": "ed_handoff、elevator_1、elevator_3、icu_admission",
      "agents": "患者、医生/护士、BedManager 或叫号/转运系统。",
      "prechecks": "ICU 有匹配空床；转运人员可用；患者适合转运。",
      "actions": "患者从急诊经 elevator_1 到 elevator_3，进入 ICU。",
      "successState": "ICU 床位占用；急诊原资源释放。",
      "blocking": "ICU 满床、拒收或转运人员不足时不启动路径。",
      "visualization": "跨楼层 stretcher 转运动画。",
      "movement": {
        "schema": "patient-move",
        "from": "current_ed_room",
        "to": "icu_admission",
        "via": [
          "ed_handoff",
          "elevator_1",
          "elevator_3"
        ],
        "transport": "stretcher",
        "acuity": "critical",
        "patientFormDuringMove": "stretcher",
        "finalForm": "bed",
        "escortRequired": true,
        "escortRoles": [
          "porter",
          "ed_nurse"
        ],
        "equipment": [
          "portable_monitor",
          "oxygen",
          "transport_bag"
        ],
        "pathPolicy": {
          "requiresPath": true,
          "useElevator": true,
          "avoidWalls": true,
          "hallwayPreference": "center",
          "stopAtDoorBeforeEntering": true
        },
        "resourcePolicy": {
          "lockBeforeMove": true,
          "releaseSourceOnArrival": true,
          "occupyTargetOnArrival": true,
          "keepSourceReservedUntilArrival": true
        },
        "failurePolicy": {
          "onNoPath": "stay_source",
          "onResourceBlocked": "stay_source",
          "onEscortUnavailable": "stay_source"
        },
        "patient_form_during_move": "stretcher",
        "final_form": "bed",
        "escort_required": true,
        "escort_roles": [
          "porter",
          "ed_nurse"
        ]
      },
      "sourceFile": "patient-movement-curated",
      "event_id": "TRANSFER_ED_TO_ICU"
    },
