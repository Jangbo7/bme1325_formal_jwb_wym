# Mock key for local dev. If backend/.env does not exist, server falls back to mock-key-001.
MOCK_API_KEY=mock-key-001

# Optional backend binding
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8787

# Optional model endpoint/model name
LLM_ENDPOINT=https://genaiapi.shanghaitech.edu.cn/api/v1/start
LLM_MODEL=deepseek-v3:671b

# Optional real model key. If empty, backend uses rule-based triage.
OPENAI_API_KEY=
LLM_API_KEY=
GPT52_API_KEY=277149ebe53440a190ee02bd66673cd1

# OpenEMR integration
OPENEMR_ENABLED=false
OPENEMR_DRY_RUN=true
OPENEMR_BASE_URL=http://localhost:8080
OPENEMR_API_BASE_PATH=/apis/default/fhir
OPENEMR_VERIFY_SSL=false
OPENEMR_TIMEOUT_SECONDS=10
OPENEMR_OUTBOUND_LOG_PATH=backend/data/openemr_outbound_payloads.log
OPENEMR_PREPARED_LOG_PATH=backend/data/openemr_prepared_payloads.log

# OpenEMR OAuth (SMART on FHIR)
# Register a confidential OAuth client in OpenEMR first.
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_OAUTH_ENABLED=true
OPENEMR_OAUTH_DISCOVERY_URL=
OPENEMR_OAUTH_TOKEN_URL=
OPENEMR_OAUTH_SCOPE=api:fhir user/Patient.write user/DocumentReference.write
OPENEMR_OAUTH_AUDIENCE=
OPENEMR_OAUTH_USE_BASIC_FALLBACK=true

# Optional legacy fallback credentials for Basic auth
OPENEMR_USERNAME=
OPENEMR_PASSWORD=

# Event bridge (A-group contract)
REDIS_MIRROR_ENABLED=true
EVENT_PRODUCER=groupA.outpatient
HOSPITAL_REDIS_HOST=127.0.0.1
HOSPITAL_REDIS_PORT=6379
HOSPITAL_REDIS_DB=0
HOSPITAL_REDIS_PASSWORD=
HOSPITAL_REDIS_CHANNEL_PREFIX=hospital
HOSPITAL_REDIS_DURABLE_STREAM_ENABLED=false
HOSPITAL_REDIS_DURABLE_STREAM_KEY=hospital:journal

# State-machine debug mode (orchestration validation)
STATE_DEBUG_ENABLED=false
STATE_DEBUG_ALLOW_FORCE=false
