# =============================================================================
# Mock key for local dev.
# =============================================================================
MOCK_API_KEY=mock-key-001

# Optional backend binding
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8787

# =============================================================================
# 🔄 LLM 供应商选择 — 三选一，修改 ACTIVE_LLM_PROVIDER 切换
# =============================================================================
# 供应商 1: 上海科技大学 GenAI 代理 (默认)
#   endpoint: https://genaiapi.shanghaitech.edu.cn/api/v1/start
#   可用模型: deepseek-v3:671b, deepseek-r1:671b, qwen-instruct 等
ACTIVE_LLM_PROVIDER=current

# 供应商 2: 阿里云 DashScope（百炼）
#   endpoint: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
#   可用模型: qwen3.7-plus, qwen3.6-flash, deepseek-v4-flash 等
# ACTIVE_LLM_PROVIDER=aliyun_dashscope

# 供应商 3: DeepSeek 官方 API（OpenAI 兼容）
#   endpoint: https://api.deepseek.com/v1/chat/completions
#   可用模型: deepseek-chat (V3), deepseek-reasoner (R1)
#   获取 key: https://platform.deepseek.com/api_keys
#   ⚠️ 需同时设置下方的 DEEPSEEK_* 变量
# ACTIVE_LLM_PROVIDER=deepseek_official

# =============================================================================
# 供应商 1 配置: 上海科技大学 (current)
# =============================================================================
CURRENT_LLM_ENDPOINT=https://genaiapi.shanghaitech.edu.cn/api/v1/start
CURRENT_LLM_MODEL=deepseek-v3:671b
CURRENT_LLM_API_KEY=

# =============================================================================
# 供应商 2 配置: 阿里云 DashScope (aliyun_dashscope)
# =============================================================================
ALIYUN_LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
ALIYUN_LLM_MODEL=deepseek-v4-flash
DASHSCOPE_API_KEY=

# =============================================================================
# 供应商 3 配置: DeepSeek 官方 (deepseek_official)
# =============================================================================
# endpoint: DeepSeek 官方 OpenAI 兼容接口
DEEPSEEK_LLM_ENDPOINT=https://api.deepseek.com/v1/chat/completions
# 模型选择: deepseek-chat (V3, 性价比高) / deepseek-reasoner (R1, 推理强)
DEEPSEEK_LLM_MODEL=deepseek-chat
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=

# =============================================================================
# 遗留变量 (向后兼容 — 当 CURRENT_* 未设置时 fallback)
# =============================================================================
LLM_ENDPOINT=https://genaiapi.shanghaitech.edu.cn/api/v1/start
LLM_MODEL=deepseek-v3:671b

OPENAI_API_KEY=
LLM_API_KEY=
GPT52_API_KEY=
DEEPSEEK_R1_API_KEY=
DEEPSEEK_V3_API_KEY=
QWEN_API_KEY=

# =============================================================================
# OpenEMR 集成
# =============================================================================
OPENEMR_ENABLED=false
OPENEMR_DRY_RUN=true
OPENEMR_BASE_URL=http://localhost:8080
OPENEMR_API_BASE_PATH=/apis/default/fhir
OPENEMR_VERIFY_SSL=false
OPENEMR_TIMEOUT_SECONDS=10
OPENEMR_OUTBOUND_LOG_PATH=backend/data/openemr_outbound_payloads.log
OPENEMR_PREPARED_LOG_PATH=backend/data/openemr_prepared_payloads.log

# OpenEMR OAuth (SMART on FHIR)
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_OAUTH_ENABLED=true
OPENEMR_OAUTH_DISCOVERY_URL=
OPENEMR_OAUTH_TOKEN_URL=
OPENEMR_OAUTH_SCOPE=api:fhir user/Patient.write user/DocumentReference.write
OPENEMR_OAUTH_AUDIENCE=
OPENEMR_OAUTH_USE_BASIC_FALLBACK=true

OPENEMR_USERNAME=
OPENEMR_PASSWORD=

# =============================================================================
# Event bridge (A-group contract)
# =============================================================================
REDIS_MIRROR_ENABLED=true
EVENT_PRODUCER=groupA.outpatient
HOSPITAL_REDIS_HOST=127.0.0.1
HOSPITAL_REDIS_PORT=6379
HOSPITAL_REDIS_DB=0
HOSPITAL_REDIS_PASSWORD=
HOSPITAL_REDIS_CHANNEL_PREFIX=hospital
HOSPITAL_REDIS_DURABLE_STREAM_ENABLED=false
HOSPITAL_REDIS_DURABLE_STREAM_KEY=hospital:journal

# =============================================================================
# State-machine debug mode
# =============================================================================
STATE_DEBUG_ENABLED=false
STATE_DEBUG_ALLOW_FORCE=false
RESET_ON_SERVER_START=false
FULLVIEW_STEP_GATE_ENABLED=false
FULLVIEW_VISUAL_COOLDOWN_MULTIPLIER=1.0
FULLVIEW_DISCHARGE_LINGER_SECONDS=30
FULLVIEW_EVENT_LISTENER_INTERVAL_SECONDS=0.5
FULLVIEW_EVENT_OBSERVE_TIMEOUT_SECONDS=30
FULLVIEW_ADMISSION_GAP_SECONDS=0
FULLVIEW_CLEANUP_IDLE_SECONDS=3
